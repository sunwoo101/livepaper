pkgbase = livepaper-git
	pkgdesc = Live wallpaper manager for Wayland using mpvpaper
	pkgver = r6.a0907c1
	pkgrel = 1
	url = https://github.com/sunwoo101/livepaper
	arch = x86_64
	license = MIT
	makedepends = dotnet-sdk
	depends = mpvpaper
	depends = dotnet-runtime
	optdepends = ffmpeg: thumbnail auto-generation for the Import Wallpaper flow
	optdepends = libpulse: pactl/parec for the Auto-Mute feature (provided by pipewire-pulse on PipeWire systems)
	optdepends = wl-clipboard: persistent clipboard for the Settings keybind Copy buttons (snippets stay copied after closing livepaper)
	provides = livepaper
	conflicts = livepaper
	options = !strip
	options = !debug
	source = livepaper-git::git+https://github.com/sunwoo101/livepaper.git
	sha256sums = SKIP

pkgname = livepaper-git
