<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:livepaper.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="720"
        x:Class="livepaper.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="livepaper"
        Width="1100" Height="720"
        MinWidth="640" MinHeight="480">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="*,Auto">

            <TabControl Grid.Row="0" x:Name="MainTabControl">

                <!-- ── Browse ── -->
                <TabItem Header="Browse">
                    <DockPanel>

                        <!-- Top bar -->
                        <Border DockPanel.Dock="Top"
                                Background="{StaticResource BgBase}"
                                Padding="16,12"
                                BorderThickness="0,0,0,1"
                                BorderBrush="{StaticResource Surface0}">
                            <DockPanel>

                                <!-- Source pills -->
                                <ListBox DockPanel.Dock="Left"
                                         Classes="pills"
                                         ItemsSource="{Binding Sources}"
                                         SelectedItem="{Binding SelectedSource}">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Name}"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- Right controls -->
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            HorizontalAlignment="Right">
                                    <TextBox Text="{Binding SearchQuery}"
                                             PlaceholderText="Search…"
                                             Width="220"
                                             IsEnabled="{Binding SelectedSource.SupportsSearch}">
                                        <TextBox.KeyBindings>
                                            <KeyBinding Gesture="Enter" Command="{Binding SearchCommand}"/>
                                        </TextBox.KeyBindings>
                                    </TextBox>
                                    <Button Content="Search"
                                            Classes="ghost"
                                            Command="{Binding SearchCommand}"
                                            IsEnabled="{Binding SelectedSource.SupportsSearch}"/>
                                    <Button Content="↺"
                                            Classes="ghost"
                                            Command="{Binding LoadWallpapersCommand}"
                                            ToolTip.Tip="Refresh"/>
                                </StackPanel>

                            </DockPanel>
                        </Border>

                        <!-- Loading bar -->
                        <ProgressBar DockPanel.Dock="Top"
                                     IsIndeterminate="True"
                                     IsVisible="{Binding IsLoading}"
                                     Height="3" CornerRadius="0"/>

                        <!-- Selection toolbar -->
                        <Border DockPanel.Dock="Bottom"
                                IsVisible="{Binding AnyBrowseSelected}"
                                Background="{StaticResource BgMantle}"
                                BorderBrush="{StaticResource Surface0}"
                                BorderThickness="0,1,0,0"
                                Padding="16,10">
                            <DockPanel>
                                <TextBlock VerticalAlignment="Center"
                                           Foreground="{StaticResource TextColor}"
                                           FontSize="13"
                                           Text="{Binding BrowseSelectedCount, StringFormat='{}{0} selected'}"/>
                                <StackPanel DockPanel.Dock="Right"
                                            Orientation="Horizontal"
                                            Spacing="8"
                                            HorizontalAlignment="Right">
                                    <Button Content="Download" Classes="accent"
                                            Command="{Binding DownloadSelectedCommand}"/>
                                    <Button Content="Cancel" Classes="ghost"
                                            Command="{Binding ClearBrowseSelectionCommand}"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>

                        <!-- Wallpaper grid -->
                        <ScrollViewer x:Name="BrowseScrollViewer"
                                      Padding="12,12,12,0">
                            <ItemsControl ItemsSource="{Binding BrowseWallpapers}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Margin="0,0,0,32"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:WallpaperCardViewModel">
                                        <Border Width="210" Margin="6" CornerRadius="10"
                                                ClipToBounds="True"
                                                Background="{StaticResource BgBase}">
                                            <Grid RowDefinitions="150,*,Auto">

                                                <Button Grid.Row="0" Padding="0"
                                                        Background="Transparent" BorderThickness="0"
                                                        Command="{Binding $parent[Window].DataContext.OpenPreviewCommand}"
                                                        CommandParameter="{Binding}">
                                                    <asyncImageLoader:AdvancedImage
                                                        Source="{Binding ThumbnailSource}"
                                                        Stretch="UniformToFill"
                                                        Width="210" Height="150"/>
                                                </Button>

                                                <TextBlock Grid.Row="1"
                                                           Text="{Binding Title}"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource TextColor}"
                                                           Margin="10,8,10,4"
                                                           FontSize="12"
                                                           MaxLines="2"/>

                                                <Button Grid.Row="2"
                                                        Content="Download &amp; Apply"
                                                        Classes="accent"
                                                        Margin="10,4,10,10"
                                                        HorizontalAlignment="Stretch"
                                                        Command="{Binding $parent[Window].DataContext.DownloadCommand}"
                                                        CommandParameter="{Binding}"/>

                                                <!-- Selection overlay -->
                                                <Border Grid.RowSpan="3"
                                                        IsVisible="{Binding IsSelected}"
                                                        BorderBrush="{StaticResource Accent}"
                                                        BorderThickness="2.5"
                                                        CornerRadius="10"
                                                        IsHitTestVisible="False"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                    </DockPanel>
                </TabItem>

                <!-- ── Library ── -->
                <TabItem Header="Library">
                    <Grid>
                        <DockPanel>

                            <!-- Header -->
                            <Border DockPanel.Dock="Top"
                                    Background="{StaticResource BgBase}"
                                    Padding="16,12"
                                    BorderThickness="0,0,0,1"
                                    BorderBrush="{StaticResource Surface0}">
                                <DockPanel>
                                    <TextBlock Text="Your downloaded wallpapers"
                                               Foreground="{StaticResource Subtext}"
                                               FontSize="13"
                                               VerticalAlignment="Center"/>
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal"
                                                Spacing="10"
                                                HorizontalAlignment="Right">
                                        <CheckBox Content="Shuffle"
                                                  IsChecked="{Binding ShuffleLibrary}"
                                                  VerticalAlignment="Center"
                                                  Foreground="{StaticResource Subtext}"/>
                                        <Button Content="Import"
                                                Classes="ghost"
                                                IsEnabled="{Binding !IsImporting}"
                                                Command="{Binding OpenImportCommand}"/>
                                        <Button Content="Play All"
                                                Classes="accent"
                                                Command="{Binding PlayLibraryCommand}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <!-- Playlist panel (bottom) -->
                            <Border DockPanel.Dock="Bottom"
                                    Background="{StaticResource BgMantle}"
                                    BorderBrush="{StaticResource Surface0}"
                                    BorderThickness="0,1,0,0"
                                    MinHeight="140">
                                <DockPanel Margin="12,8">

                                    <!-- Playlist header -->
                                    <DockPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                        <TextBlock Text="PLAYLIST"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Muted}"
                                                   LetterSpacing="2"
                                                   VerticalAlignment="Center"/>
                                        <StackPanel DockPanel.Dock="Right"
                                                    Orientation="Horizontal"
                                                    Spacing="6"
                                                    HorizontalAlignment="Right">
                                            <Button Classes="ghost"
                                                    Width="32" Height="32" Padding="0"
                                                    ToolTip.Tip="Playlist Settings"
                                                    Command="{Binding TogglePlaylistSettingsCommand}">
                                                <TextBlock Text="⚙" FontSize="18"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Button>
                                            <Button Classes="ghost"
                                                    Width="32" Height="32" Padding="0"
                                                    ToolTip.Tip="Load Playlist"
                                                    Command="{Binding OpenLoadPlaylistCommand}">
                                                <TextBlock Text="📂" FontSize="16"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Button>
                                            <Button Classes="ghost"
                                                    Width="32" Height="32" Padding="0"
                                                    ToolTip.Tip="Save Playlist"
                                                    Command="{Binding OpenSavePlaylistCommand}">
                                                <TextBlock Text="💾" FontSize="16"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Button>
                                            <Button Content="▶ Play"
                                                    Classes="accent"
                                                    Command="{Binding PlayCustomPlaylistCommand}"/>
                                        </StackPanel>
                                    </DockPanel>

                                    <!-- Empty state -->
                                    <TextBlock IsVisible="{Binding IsPlaylistEmpty}"
                                               Text="Add wallpapers using the + button on each card"
                                               Foreground="{StaticResource Muted}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"/>

                                    <!-- Playlist thumbnails -->
                                    <Grid IsVisible="{Binding !IsPlaylistEmpty}"
                                          ClipToBounds="True">
                                        <ScrollViewer x:Name="PlaylistScrollViewer"
                                                      HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Disabled">
                                        <ItemsControl x:Name="PlaylistItemsControl"
                                                      ItemsSource="{Binding PlaylistItems}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" Spacing="6"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:WallpaperCardViewModel">
                                                    <Border Classes="playlist-item"
                                                            Width="100" CornerRadius="6"
                                                            ClipToBounds="True"
                                                            Background="{StaticResource BgBase}">
                                                        <Border.Styles>
                                                            <Style Selector="Border.playlist-item Grid.play-overlay">
                                                                <Setter Property="Opacity" Value="0"/>
                                                            </Style>
                                                            <Style Selector="Border.playlist-item:pointerover Grid.play-overlay">
                                                                <Setter Property="Opacity" Value="1"/>
                                                            </Style>
                                                        </Border.Styles>
                                                        <Grid Height="90">
                                                            <asyncImageLoader:AdvancedImage
                                                                Source="{Binding ThumbnailSource}"
                                                                Stretch="UniformToFill"
                                                                Width="100" Height="90"/>
                                                            <Grid Classes="play-overlay"
                                                                  Background="#80000000"
                                                                  IsHitTestVisible="False">
                                                                <TextBlock Text="▶"
                                                                           FontSize="28"
                                                                           Foreground="White"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"/>
                                                            </Grid>
                                                            <Border Background="#99000000"
                                                                    VerticalAlignment="Bottom"
                                                                    Padding="4,2">
                                                                <TextBlock Text="{Binding Title}"
                                                                           FontSize="10"
                                                                           Foreground="White"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </Border>
                                                            <Button HorizontalAlignment="Right"
                                                                    VerticalAlignment="Top"
                                                                    Margin="0,5,5,0"
                                                                    Width="24" Height="24"
                                                                    CornerRadius="12" Padding="0"
                                                                    BorderThickness="0"
                                                                    Background="{StaticResource BgCrust}"
                                                                    Command="{Binding $parent[Window].DataContext.RemoveFromPlaylistCommand}"
                                                                    CommandParameter="{Binding}">
                                                                <TextBlock Text="−"
                                                                           FontSize="12" FontWeight="Bold"
                                                                           Foreground="{StaticResource Accent}"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"/>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        </ScrollViewer>
                                        <!-- Drop position indicator -->
                                        <Border x:Name="PlaylistDropIndicator"
                                                Width="2" CornerRadius="1"
                                                VerticalAlignment="Stretch"
                                                HorizontalAlignment="Left"
                                                Background="{StaticResource Accent}"
                                                IsHitTestVisible="False"
                                                IsVisible="False"/>
                                    </Grid>

                                </DockPanel>
                            </Border>

                            <!-- Selection toolbar (above playlist strip) -->
                            <Border DockPanel.Dock="Bottom"
                                    IsVisible="{Binding AnyLibrarySelected}"
                                    Background="{StaticResource BgMantle}"
                                    BorderBrush="{StaticResource Surface0}"
                                    BorderThickness="0,1,0,0"
                                    Padding="16,10">
                                <DockPanel>
                                    <TextBlock VerticalAlignment="Center"
                                               Foreground="{StaticResource TextColor}"
                                               FontSize="13"
                                               Text="{Binding LibrarySelectedCount, StringFormat='{}{0} selected'}"/>
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal"
                                                Spacing="8"
                                                HorizontalAlignment="Right">
                                        <Button Content="Add to Playlist" Classes="ghost"
                                                Command="{Binding AddSelectedToPlaylistCommand}"/>
                                        <Button Content="Remove from Playlist" Classes="ghost"
                                                Command="{Binding RemoveSelectedFromPlaylistCommand}"/>
                                        <Button Content="Delete" Classes="danger"
                                                Command="{Binding DeleteSelectedCommand}"/>
                                        <Button Content="Cancel" Classes="ghost"
                                                Command="{Binding ClearLibrarySelectionCommand}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Border>

                            <!-- Library grid -->
                            <ScrollViewer x:Name="LibraryScrollViewer" Padding="12,12,12,0">
                                <ItemsControl ItemsSource="{Binding LibraryWallpapers}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Margin="0,0,0,32"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:WallpaperCardViewModel">
                                            <Border Width="210" Margin="6" CornerRadius="10"
                                                    ClipToBounds="True"
                                                    Background="{StaticResource BgBase}">
                                                <Border.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="Add to Playlist"
                                                                  Command="{Binding AddToPlaylistCommand}"/>
                                                    </ContextMenu>
                                                </Border.ContextMenu>
                                                <Grid RowDefinitions="150,*,Auto">

                                                    <!-- Thumbnail + checkmark -->
                                                    <Grid Grid.Row="0">
                                                        <Button Padding="0"
                                                                Background="Transparent" BorderThickness="0"
                                                                Command="{Binding $parent[Window].DataContext.OpenPreviewCommand}"
                                                                CommandParameter="{Binding}">
                                                            <asyncImageLoader:AdvancedImage
                                                                Source="{Binding ThumbnailSource}"
                                                                Stretch="UniformToFill"
                                                                Width="210" Height="150"/>
                                                        </Button>

                                                        <!-- Checkmark badge -->
                                                        <Button HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="0,5,5,0"
                                                                Width="24" Height="24"
                                                                CornerRadius="12" Padding="0"
                                                                BorderThickness="0"
                                                                Background="{StaticResource BgCrust}"
                                                                Command="{Binding AddToPlaylistCommand}">
                                                            <TextBlock Text="{Binding CheckmarkText}"
                                                                       FontSize="12" FontWeight="Bold"
                                                                       Foreground="{StaticResource Accent}"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Button>
                                                    </Grid>

                                                    <TextBlock Grid.Row="1"
                                                               Text="{Binding Title}"
                                                               TextWrapping="Wrap"
                                                               Foreground="{StaticResource TextColor}"
                                                               Margin="10,8,10,4"
                                                               FontSize="12"
                                                               MaxLines="2"/>

                                                    <Grid Grid.Row="2" ColumnDefinitions="*,Auto" Margin="10,4,10,10">
                                                        <Button Grid.Column="0"
                                                                Content="Apply"
                                                                Classes="accent"
                                                                HorizontalAlignment="Stretch"
                                                                Command="{Binding $parent[Window].DataContext.ApplyCommand}"
                                                                CommandParameter="{Binding}"/>
                                                        <Button Grid.Column="1"
                                                                Content="Delete"
                                                                Classes="danger"
                                                                Margin="6,0,0,0"
                                                                Command="{Binding $parent[Window].DataContext.DeleteCommand}"
                                                                CommandParameter="{Binding}"/>
                                                    </Grid>

                                                    <!-- Selection overlay -->
                                                    <Border Grid.RowSpan="3"
                                                            IsVisible="{Binding IsSelected}"
                                                            BorderBrush="{StaticResource Accent}"
                                                            BorderThickness="2.5"
                                                            CornerRadius="10"
                                                            IsHitTestVisible="False"/>

                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                        </DockPanel>

                        <!-- Playlist settings overlay -->
                        <Grid IsVisible="{Binding IsPlaylistSettingsOpen}"
                              Background="#B2000000">
                            <Border Background="{StaticResource BgBase}" CornerRadius="12" Padding="24"
                                    Width="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <StackPanel Spacing="16">
                                    <TextBlock Text="Playlist Settings" FontSize="15" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextColor}"/>

                                    <!-- Order -->
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="ORDER"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Muted}"
                                                   LetterSpacing="2"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <ToggleButton Content="Sequential"
                                                          IsChecked="{Binding IsSequential}">
                                                <ToggleButton.Styles>
                                                    <Style Selector="ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
                                                        <Setter Property="Background" Value="{StaticResource Accent}"/>
                                                    </Style>
                                                    <Style Selector="ToggleButton:checked">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentFg}"/>
                                                    </Style>
                                                </ToggleButton.Styles>
                                            </ToggleButton>
                                            <ToggleButton Content="Shuffle"
                                                          IsChecked="{Binding PlaylistShuffle}">
                                                <ToggleButton.Styles>
                                                    <Style Selector="ToggleButton:checked /template/ ContentPresenter#PART_ContentPresenter">
                                                        <Setter Property="Background" Value="{StaticResource Accent}"/>
                                                    </Style>
                                                    <Style Selector="ToggleButton:checked">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentFg}"/>
                                                    </Style>
                                                </ToggleButton.Styles>
                                            </ToggleButton>
                                        </StackPanel>
                                    </StackPanel>

                                    <CheckBox Content="Override global rotation settings"
                                              IsChecked="{Binding OverrideGlobalSettings}"
                                              Foreground="{StaticResource TextColor}"/>

                                    <!-- Interval (per-playlist override) -->
                                    <StackPanel Spacing="8" IsEnabled="{Binding OverrideGlobalSettings}">
                                        <TextBlock Text="SWITCH EVERY"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Muted}"
                                                   LetterSpacing="2"/>
                                        <CheckBox Content="Switch when video ends"
                                                  IsChecked="{Binding AdvanceOnVideoEnd}"
                                                  Foreground="{StaticResource TextColor}"/>
                                        <StackPanel Orientation="Horizontal" Spacing="12"
                                                    IsEnabled="{Binding !AdvanceOnVideoEnd}">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Hours" FontSize="12"
                                                           Foreground="{StaticResource Subtext}"/>
                                                <NumericUpDown Value="{Binding IntervalHours}"
                                                               Minimum="0" Maximum="99"
                                                               FormatString="0" Width="108"/>
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Minutes" FontSize="12"
                                                           Foreground="{StaticResource Subtext}"/>
                                                <NumericUpDown Value="{Binding IntervalMinutes}"
                                                               Minimum="0" Maximum="59"
                                                               FormatString="0" Width="108"/>
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Seconds" FontSize="12"
                                                           Foreground="{StaticResource Subtext}"/>
                                                <NumericUpDown Value="{Binding IntervalSeconds}"
                                                               Minimum="0" Maximum="59"
                                                               FormatString="0" Width="108"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>

                                    <Button Content="Close"
                                            Classes="ghost"
                                            HorizontalAlignment="Right"
                                            Command="{Binding ClosePlaylistSettingsCommand}"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                    </Grid>
                </TabItem>

                <!-- ── Settings ── -->
                <TabItem Header="Settings">
                    <ScrollViewer>
                        <StackPanel Margin="28" Spacing="20">

                            <TextBlock Text="Playback"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource Muted}"
                                       LetterSpacing="2"/>
                            <Border Background="{StaticResource BgBase}" CornerRadius="10" Padding="16">
                                <StackPanel Spacing="12">
                                    <CheckBox Content="Loop" IsChecked="{Binding Loop}"
                                              Foreground="{StaticResource TextColor}"/>
                                    <CheckBox Content="Mute audio" IsChecked="{Binding NoAudio}"
                                              Foreground="{StaticResource TextColor}"/>
                                    <CheckBox Content="Disable cache" IsChecked="{Binding DisableCache}"
                                              Foreground="{StaticResource TextColor}"/>
                                    <Grid ColumnDefinitions="Auto,*,Auto" Margin="0,4,0,0"
                                          IsEnabled="{Binding !NoAudio}">
                                        <TextBlock Grid.Column="0" Text="Volume"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextColor}"
                                                   Width="80"/>
                                        <Slider Grid.Column="1"
                                                Minimum="0" Maximum="100"
                                                TickFrequency="1"
                                                IsSnapToTickEnabled="True"
                                                Value="{Binding Volume}"
                                                VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Volume}"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource Subtext}"
                                                   Width="30" TextAlignment="Right"
                                                   Margin="8,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="PLAYLIST"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource Muted}"
                                       LetterSpacing="2"/>
                            <Border Background="{StaticResource BgBase}" CornerRadius="10" Padding="16">
                                <StackPanel Spacing="12">
                                    <CheckBox Content="Switch when video ends"
                                              IsChecked="{Binding GlobalAdvanceOnVideoEnd}"
                                              Foreground="{StaticResource TextColor}"/>
                                    <StackPanel Spacing="6"
                                                IsEnabled="{Binding !GlobalAdvanceOnVideoEnd}">
                                        <TextBlock Text="SWITCH EVERY"
                                                   FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource Muted}"
                                                   LetterSpacing="2"/>
                                        <StackPanel Orientation="Horizontal" Spacing="12">
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Hours" FontSize="12"
                                                           Foreground="{StaticResource Subtext}"/>
                                                <NumericUpDown Value="{Binding GlobalIntervalHours}"
                                                               Minimum="0" Maximum="99"
                                                               FormatString="0" Width="108"/>
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Minutes" FontSize="12"
                                                           Foreground="{StaticResource Subtext}"/>
                                                <NumericUpDown Value="{Binding GlobalIntervalMinutes}"
                                                               Minimum="0" Maximum="59"
                                                               FormatString="0" Width="108"/>
                                            </StackPanel>
                                            <StackPanel Spacing="6">
                                                <TextBlock Text="Seconds" FontSize="12"
                                                           Foreground="{StaticResource Subtext}"/>
                                                <NumericUpDown Value="{Binding GlobalIntervalSeconds}"
                                                               Minimum="0" Maximum="59"
                                                               FormatString="0" Width="108"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="AUTO-MUTE"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource Muted}"
                                       LetterSpacing="2"/>
                            <Border Background="{StaticResource BgBase}" CornerRadius="10" Padding="16">
                                <StackPanel Spacing="12">
                                    <CheckBox Content="Mute when system audio plays"
                                              IsChecked="{Binding AutoMute}"
                                              Foreground="{StaticResource TextColor}"/>
                                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,12,Auto,12,Auto"
                                          IsEnabled="{Binding AutoMute}">
                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="Mute after"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextColor}"
                                                   Margin="0,0,16,0"/>
                                        <NumericUpDown Grid.Row="0" Grid.Column="1"
                                                       Value="{Binding AutoMuteDelayMs}"
                                                       Minimum="0" Maximum="30000" Increment="100"
                                                       FormatString="0"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2"
                                                   Text="ms" VerticalAlignment="Center"
                                                   Foreground="{StaticResource Subtext}"
                                                   Margin="8,0,0,0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="0"
                                                   Text="Unmute after"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextColor}"
                                                   Margin="0,0,16,0"/>
                                        <NumericUpDown Grid.Row="2" Grid.Column="1"
                                                       Value="{Binding AutoUnmuteDelayMs}"
                                                       Minimum="0" Maximum="30000" Increment="100"
                                                       FormatString="0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2"
                                                   Text="ms" VerticalAlignment="Center"
                                                   Foreground="{StaticResource Subtext}"
                                                   Margin="8,0,0,0"/>
                                        <TextBlock Grid.Row="4" Grid.Column="0"
                                                   Text="Minimum level"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextColor}"
                                                   Margin="0,0,16,0"/>
                                        <NumericUpDown Grid.Row="4" Grid.Column="1"
                                                       Value="{Binding AutoMuteThresholdDb}"
                                                       Minimum="-80" Maximum="0" Increment="1"
                                                       FormatString="0"/>
                                        <TextBlock Grid.Row="4" Grid.Column="2"
                                                   Text="dB" VerticalAlignment="Center"
                                                   Foreground="{StaticResource Subtext}"
                                                   Margin="8,0,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="MEMORY"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource Muted}"
                                       LetterSpacing="2"/>
                            <Border Background="{StaticResource BgBase}" CornerRadius="10" Padding="16">
                                <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,12,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Text="Demuxer max bytes"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextColor}"
                                               Margin="0,0,16,0"/>
                                    <NumericUpDown Grid.Row="0" Grid.Column="1"
                                                   Value="{Binding DemuxerMaxBytes}"
                                                   Minimum="1" Maximum="10000" Increment="1"
                                                   FormatString="0"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2"
                                               Text="MiB" VerticalAlignment="Center"
                                               Foreground="{StaticResource Subtext}"
                                               Margin="8,0,0,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Text="Demuxer max back bytes"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextColor}"
                                               Margin="0,0,16,0"/>
                                    <NumericUpDown Grid.Row="2" Grid.Column="1"
                                                   Value="{Binding DemuxerMaxBackBytes}"
                                                   Minimum="1" Maximum="10000" Increment="1"
                                                   FormatString="0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2"
                                               Text="MiB" VerticalAlignment="Center"
                                               Foreground="{StaticResource Subtext}"
                                               Margin="8,0,0,0"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="RENDERING"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource Muted}"
                                       LetterSpacing="2"/>
                            <Border Background="{StaticResource BgBase}" CornerRadius="10" Padding="16">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="Hardware decoding"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource TextColor}"/>
                                    <ComboBox Grid.Column="1"
                                              ItemsSource="{Binding HwDecOptions}"
                                              SelectedItem="{Binding HwDec}"
                                              Width="130"/>
                                </Grid>
                            </Border>

                            <TextBlock Text="BEHAVIOR"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource Muted}"
                                       LetterSpacing="2"/>
                            <Border Background="{StaticResource BgBase}" CornerRadius="10" Padding="16">
                                <CheckBox Content="Resume from last wallpaper"
                                          IsChecked="{Binding ResumeFromLast}"
                                          Foreground="{StaticResource TextColor}"/>
                            </Border>

                            <TextBlock Text="SOURCES"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource Muted}"
                                       LetterSpacing="2"/>
                            <Border Background="{StaticResource BgBase}" CornerRadius="10" Padding="16">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Wallpaper Engine workshop folder"
                                               Foreground="{StaticResource TextColor}"/>
                                    <Grid ColumnDefinitions="*,Auto" >
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding WallpaperEnginePath}"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource Subtext}"
                                                   ToolTip.Tip="{Binding WallpaperEnginePath}"
                                                   Margin="0,0,8,0"/>
                                        <Button Grid.Column="1"
                                                Content="Browse"
                                                Classes="ghost"
                                                Command="{Binding PickWallpaperEngineFolderCommand}"/>
                                    </Grid>
                                    <CheckBox Content="Copy files instead of symlinking"
                                              IsChecked="{Binding WeCopyFiles}"
                                              Foreground="{StaticResource TextColor}"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="COMMAND PREVIEW"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource Muted}"
                                       LetterSpacing="2"/>
                            <Border Background="{StaticResource BgCrust}" CornerRadius="10" Padding="14">
                                <TextBlock Text="{Binding MpvOptionsPreview}"
                                           FontFamily="Monospace"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource Accent}"/>
                            </Border>

                            <TextBlock Text="KEYBINDS"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource Muted}"
                                       LetterSpacing="2"/>
                            <Border Background="{StaticResource BgCrust}" CornerRadius="10" Padding="14">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Bind these commands in your compositor config:"
                                               Foreground="{StaticResource Subtext}"
                                               FontSize="12"/>
                                    <Grid ColumnDefinitions="Auto,*,Auto" RowDefinitions="Auto,8,Auto,8,Auto,8,Auto,8,Auto,8,Auto,8,Auto,8,Auto,8,Auto,8,Auto">
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Toggle mute"
                                                   Foreground="{StaticResource TextColor}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1"
                                                   Text="livepaper --action=toggle-mute"
                                                   FontFamily="Monospace" FontSize="12"
                                                   Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                                        <Button Grid.Row="0" Grid.Column="2" Content="Copy" Classes="ghost" FontSize="11" Margin="8,0,0,0"
                                                Command="{Binding CopyTextCommand}" CommandParameter="livepaper --action=toggle-mute"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Toggle pause"
                                                   Foreground="{StaticResource TextColor}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1"
                                                   Text="livepaper --action=toggle-pause"
                                                   FontFamily="Monospace" FontSize="12"
                                                   Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                                        <Button Grid.Row="2" Grid.Column="2" Content="Copy" Classes="ghost" FontSize="11" Margin="8,0,0,0"
                                                Command="{Binding CopyTextCommand}" CommandParameter="livepaper --action=toggle-pause"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Stop"
                                                   Foreground="{StaticResource TextColor}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1"
                                                   Text="livepaper --action=stop"
                                                   FontFamily="Monospace" FontSize="12"
                                                   Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                                        <Button Grid.Row="4" Grid.Column="2" Content="Copy" Classes="ghost" FontSize="11" Margin="8,0,0,0"
                                                Command="{Binding CopyTextCommand}" CommandParameter="livepaper --action=stop"/>

                                        <TextBlock Grid.Row="6" Grid.Column="0" Text="Play (restore)"
                                                   Foreground="{StaticResource TextColor}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Row="6" Grid.Column="1"
                                                   Text="livepaper --action=play"
                                                   FontFamily="Monospace" FontSize="12"
                                                   Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                                        <Button Grid.Row="6" Grid.Column="2" Content="Copy" Classes="ghost" FontSize="11" Margin="8,0,0,0"
                                                Command="{Binding CopyTextCommand}" CommandParameter="livepaper --action=play"/>

                                        <TextBlock Grid.Row="8" Grid.Column="0" Text="Toggle stop/play"
                                                   Foreground="{StaticResource TextColor}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Row="8" Grid.Column="1"
                                                   Text="livepaper --action=toggle-play"
                                                   FontFamily="Monospace" FontSize="12"
                                                   Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                                        <Button Grid.Row="8" Grid.Column="2" Content="Copy" Classes="ghost" FontSize="11" Margin="8,0,0,0"
                                                Command="{Binding CopyTextCommand}" CommandParameter="livepaper --action=toggle-play"/>

                                        <TextBlock Grid.Row="10" Grid.Column="0" Text="Next wallpaper"
                                                   Foreground="{StaticResource TextColor}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Row="10" Grid.Column="1"
                                                   Text="livepaper --action=next-wallpaper"
                                                   FontFamily="Monospace" FontSize="12"
                                                   Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                                        <Button Grid.Row="10" Grid.Column="2" Content="Copy" Classes="ghost" FontSize="11" Margin="8,0,0,0"
                                                Command="{Binding CopyTextCommand}" CommandParameter="livepaper --action=next-wallpaper"/>

                                        <TextBlock Grid.Row="12" Grid.Column="0" Text="Previous wallpaper"
                                                   Foreground="{StaticResource TextColor}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Row="12" Grid.Column="1"
                                                   Text="livepaper --action=previous-wallpaper"
                                                   FontFamily="Monospace" FontSize="12"
                                                   Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                                        <Button Grid.Row="12" Grid.Column="2" Content="Copy" Classes="ghost" FontSize="11" Margin="8,0,0,0"
                                                Command="{Binding CopyTextCommand}" CommandParameter="livepaper --action=previous-wallpaper"/>

                                        <TextBlock Grid.Row="14" Grid.Column="0" Text="Random wallpaper"
                                                   Foreground="{StaticResource TextColor}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Row="14" Grid.Column="1"
                                                   Text="livepaper --action=random"
                                                   FontFamily="Monospace" FontSize="12"
                                                   Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                                        <Button Grid.Row="14" Grid.Column="2" Content="Copy" Classes="ghost" FontSize="11" Margin="8,0,0,0"
                                                Command="{Binding CopyTextCommand}" CommandParameter="livepaper --action=random"/>

                                        <TextBlock Grid.Row="16" Grid.Column="0" Text="Volume up"
                                                   Foreground="{StaticResource TextColor}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Row="16" Grid.Column="1"
                                                   Text="livepaper --action=volume-up"
                                                   FontFamily="Monospace" FontSize="12"
                                                   Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                                        <Button Grid.Row="16" Grid.Column="2" Content="Copy" Classes="ghost" FontSize="11" Margin="8,0,0,0"
                                                Command="{Binding CopyTextCommand}" CommandParameter="livepaper --action=volume-up"/>

                                        <TextBlock Grid.Row="18" Grid.Column="0" Text="Volume down"
                                                   Foreground="{StaticResource TextColor}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Row="18" Grid.Column="1"
                                                   Text="livepaper --action=volume-down"
                                                   FontFamily="Monospace" FontSize="12"
                                                   Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                                        <Button Grid.Row="18" Grid.Column="2" Content="Copy" Classes="ghost" FontSize="11" Margin="8,0,0,0"
                                                Command="{Binding CopyTextCommand}" CommandParameter="livepaper --action=volume-down"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="AUTOSTART"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource Muted}"
                                       LetterSpacing="2"/>
                            <Border Background="{StaticResource BgCrust}" CornerRadius="10" Padding="14">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="Add this to your compositor's autostart to restore your wallpaper on login:"
                                               Foreground="{StaticResource Subtext}"
                                               FontSize="12"/>
                                    <Grid ColumnDefinitions="Auto,*,Auto">
                                        <TextBlock Grid.Column="0" Text="Restore wallpaper"
                                                   Foreground="{StaticResource TextColor}" FontSize="12"
                                                   VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="livepaper --restore"
                                                   FontFamily="Monospace" FontSize="12"
                                                   Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                                        <Button Grid.Column="2" Content="Copy" Classes="ghost" FontSize="11" Margin="8,0,0,0"
                                                Command="{Binding CopyTextCommand}" CommandParameter="livepaper --restore"/>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Reset to Defaults"
                                        Classes="ghost"
                                        Command="{Binding ResetMpvOptionsCommand}"/>
                                <Button Content="Clear Library"
                                        Classes="danger"
                                        Command="{Binding OpenClearLibraryCommand}"/>
                            </StackPanel>

                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

            </TabControl>

        <!-- Status bar -->
        <Border Grid.Row="1"
                Background="{StaticResource BgCrust}"
                Padding="16,6">
            <TextBlock Text="{Binding StatusMessage}"
                       Foreground="{StaticResource Muted}"
                       FontSize="11"/>
        </Border>

        <!-- Download progress modal -->
        <Grid Grid.RowSpan="2" IsVisible="{Binding IsDownloading}" Background="#B2000000">
            <Border Background="{StaticResource BgBase}" CornerRadius="12" Padding="28"
                    Width="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="14">
                    <TextBlock Text="Downloading" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextColor}"/>
                    <TextBlock Text="{Binding DownloadTitle}" FontSize="12"
                               Foreground="{StaticResource Subtext}"
                               TextTrimming="CharacterEllipsis"/>
                    <ProgressBar Value="{Binding DownloadProgress}"
                                 Minimum="0" Maximum="1"
                                 IsIndeterminate="{Binding DownloadIndeterminate}"
                                 Height="6" CornerRadius="3"/>
                    <TextBlock FontSize="11" Foreground="{StaticResource Muted}"
                               HorizontalAlignment="Right">
                        <TextBlock.Text>
                            <Binding Path="DownloadProgress" StringFormat="{}{0:P0}"/>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Image preview modal -->
        <Grid Grid.RowSpan="2" IsVisible="{Binding PreviewCard, Converter={x:Static ObjectConverters.IsNotNull}}">
            <Button Classes="backdrop"
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch"
                    BorderThickness="0"
                    Command="{Binding ClosePreviewCommand}"/>

            <Border Background="{StaticResource BgBase}" CornerRadius="12" Padding="16"
                    MaxWidth="860" MaxHeight="600"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid RowDefinitions="*,Auto">

                    <asyncImageLoader:AdvancedImage Grid.Row="0"
                        Source="{Binding PreviewCard.ThumbnailSource}"
                        Stretch="Uniform"
                        MaxWidth="828" MaxHeight="500"/>

                    <Grid Grid.Row="1" ColumnDefinitions="*,Auto,Auto" Margin="0,12,0,0">
                        <TextBlock Grid.Column="0"
                                   Text="{Binding PreviewCard.Title}"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource TextColor}"
                                   FontSize="13" TextTrimming="CharacterEllipsis"/>
                        <Button Grid.Column="1"
                                Content="Download &amp; Apply"
                                Classes="accent"
                                Margin="8,0,0,0"
                                IsVisible="{Binding PreviewCard.LibraryItem, Converter={x:Static ObjectConverters.IsNull}}"
                                Command="{Binding DownloadCommand}"
                                CommandParameter="{Binding PreviewCard}"/>
                        <Button Grid.Column="1"
                                Content="Apply"
                                Classes="accent"
                                Margin="8,0,0,0"
                                IsVisible="{Binding PreviewCard.LibraryItem, Converter={x:Static ObjectConverters.IsNotNull}}"
                                Command="{Binding ApplyCommand}"
                                CommandParameter="{Binding PreviewCard}"/>
                        <Button Grid.Column="2"
                                Content="Close"
                                Classes="ghost"
                                Margin="8,0,0,0"
                                Command="{Binding ClosePreviewCommand}"/>
                    </Grid>

                </Grid>
            </Border>
        </Grid>

        <!-- Error modal -->
        <Grid Grid.RowSpan="2" IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}"
              Background="#B2000000">
            <Border Background="{StaticResource BgBase}" CornerRadius="12" Padding="28"
                    Width="420" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="14">
                    <TextBlock Text="{Binding ErrorTitle}" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextColor}"/>
                    <TextBlock Text="{Binding ErrorMessage}" FontSize="12"
                               Foreground="{StaticResource TextColor}"
                               TextWrapping="Wrap"/>
                    <Button Content="OK" Classes="ghost" HorizontalAlignment="Right"
                            Command="{Binding DismissErrorCommand}"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Clear library confirmation modal -->
        <Grid Grid.RowSpan="2" IsVisible="{Binding IsClearLibraryOpen}" Background="#B2000000">
            <Border Background="{StaticResource BgBase}" CornerRadius="12" Padding="28"
                    Width="380" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="14">
                    <TextBlock Text="Clear Library" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource Danger}"/>
                    <TextBlock Text="This will permanently delete all downloaded wallpapers from disk. This cannot be undone."
                               FontSize="12" Foreground="{StaticResource TextColor}" TextWrapping="Wrap"/>
                    <TextBlock FontSize="12" Foreground="{StaticResource Muted}"
                               IsVisible="{Binding !ClearLibraryReady}">
                        <TextBlock.Text>
                            <MultiBinding StringFormat="You can confirm in {0}s…">
                                <Binding Path="ClearLibraryCountdown"/>
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="Cancel" Classes="ghost"
                                Command="{Binding CancelClearLibraryCommand}"/>
                        <Button Content="Delete All" Classes="danger"
                                IsEnabled="{Binding ClearLibraryReady}"
                                Command="{Binding ConfirmClearLibraryCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Save playlist modal -->
        <Grid Grid.RowSpan="2" IsVisible="{Binding IsSavePlaylistOpen}" Background="#B2000000">
            <Border Background="{StaticResource BgBase}" CornerRadius="12" Padding="24"
                    Width="380" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="14">
                    <TextBlock Text="Save Playlist" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextColor}"/>
                    <StackPanel Spacing="6">
                        <TextBlock Text="NAME"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource Muted}"
                                   LetterSpacing="2"/>
                        <AutoCompleteBox Text="{Binding SavePlaylistName, Mode=TwoWay}"
                                         ItemsSource="{Binding AvailablePlaylists}"
                                         MinimumPrefixLength="0"
                                         FilterMode="ContainsOrdinalCaseSensitive"
                                         PlaceholderText="My playlist"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="Cancel" Classes="ghost"
                                Command="{Binding CancelSavePlaylistCommand}"/>
                        <Button Content="Save" Classes="accent"
                                IsDefault="True"
                                Command="{Binding ConfirmSavePlaylistCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Load playlist modal -->
        <Grid Grid.RowSpan="2" IsVisible="{Binding IsLoadPlaylistOpen}" Background="#B2000000">
            <Border Background="{StaticResource BgBase}" CornerRadius="12" Padding="24"
                    Width="380" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="14">
                    <TextBlock Text="Load Playlist" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextColor}"/>
                    <StackPanel Spacing="6">
                        <TextBlock Text="PLAYLIST"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource Muted}"
                                   LetterSpacing="2"/>
                        <ComboBox ItemsSource="{Binding AvailablePlaylists}"
                                  SelectedItem="{Binding SelectedPlaylistToLoad}"
                                  HorizontalAlignment="Stretch"
                                  IsVisible="{Binding AvailablePlaylists.Count}"/>
                        <TextBlock Text="No saved playlists"
                                   FontSize="12"
                                   Foreground="{StaticResource Muted}"
                                   IsVisible="{Binding !AvailablePlaylists.Count}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="Cancel" Classes="ghost"
                                Command="{Binding CancelLoadPlaylistCommand}"/>
                        <Button Content="Load" Classes="accent"
                                IsDefault="True"
                                IsEnabled="{Binding SelectedPlaylistToLoad, Converter={x:Static ObjectConverters.IsNotNull}}"
                                Command="{Binding ConfirmLoadPlaylistCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Import wallpaper modal -->
        <Grid Grid.RowSpan="2" IsVisible="{Binding IsImportOpen}" Background="#B2000000">
            <Border Background="{StaticResource BgBase}" CornerRadius="12" Padding="24"
                    Width="380" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel Spacing="14">
                    <TextBlock Text="Import Wallpaper" FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource TextColor}"/>
                    <StackPanel Spacing="6">
                        <TextBlock Text="TITLE"
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource Muted}"
                                   LetterSpacing="2"/>
                        <TextBox Text="{Binding ImportTitle}"
                                 PlaceholderText="My wallpaper"/>
                        <TextBlock Text="A thumbnail will be auto-generated from the video."
                                   FontSize="11"
                                   Foreground="{StaticResource Muted}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                        <Button Content="Cancel" Classes="ghost"
                                Command="{Binding CancelImportCommand}"/>
                        <Button Content="Import" Classes="accent"
                                IsDefault="True"
                                IsEnabled="{Binding !IsImporting}"
                                Command="{Binding ConfirmImportCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Drag preview (floats with cursor) -->
        <Canvas x:Name="DragPreviewCanvas"
                Grid.RowSpan="2"
                IsHitTestVisible="False"
                IsVisible="False">
            <Border x:Name="DragPreviewBorder"
                    Width="50" Height="45"
                    CornerRadius="4"
                    ClipToBounds="True"
                    Opacity="0.85">
                <asyncImageLoader:AdvancedImage x:Name="DragPreviewImage"
                    Stretch="UniformToFill"
                    Width="50" Height="45"/>
            </Border>
        </Canvas>

    </Grid>
</Window>
